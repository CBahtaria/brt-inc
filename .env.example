# BRT Inc. environment variables
# Copy to .env and fill in values — never commit .env

# Internal tools password hash (SHA-256 of your chosen password)
# Generate with: node -e "const c=require('crypto');console.log(c.createHash('sha256').update(process.argv[1]).digest('hex'))" YOUR_PASSWORD
BRT_AUTH_HASH=

# Stripe payment links (set via stripe-update.sh after Stripe account creation)
STRIPE_STARTER_URL=https://buy.stripe.com/PLACEHOLDER
STRIPE_PROFESSIONAL_URL=https://buy.stripe.com/PLACEHOLDER
STRIPE_CUSTOM_URL=https://buy.stripe.com/PLACEHOLDER

# Supabase (server-side only — SERVICE_ROLE_KEY must never be exposed client-side)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend email API (server-side only)
RESEND_API_KEY=

# Stripe server-side keys (never expose to client)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
