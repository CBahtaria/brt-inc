{
  "functions": {
    "api/contact.js": { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://va.vercel-scripts.com https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://vitals.vercel-insights.com https://*.supabase.co wss://*.supabase.co https://cdn.jsdelivr.net https://unpkg.com; worker-src 'self' blob:; media-src 'self' blob: https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto:; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/tools",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/onboard",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/agreements",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/runbooks",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/src/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/privacy",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/trust",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/accessibility",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/paths/soc2-readiness",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/tools", "destination": "/tools.html" },
    { "source": "/crm", "destination": "/src/crm/crm.html" },
    { "source": "/proposals", "destination": "/src/proposals/proposal-generator.html" },
    { "source": "/invoice", "destination": "/src/proposals/invoice.html" },
    { "source": "/status", "destination": "/src/status/status-dashboard.html" },
    { "source": "/casestudy/sentinel", "destination": "/src/casestudy/sentinel-audit.html" },
    { "source": "/casestudy/uav-stack", "destination": "/src/casestudy/uav-stack.html" },
    { "source": "/casestudy/maize-classifier", "destination": "/src/casestudy/maize-classifier.html" },
    { "source": "/casestudy/eswatini-dashboard", "destination": "/src/casestudy/eswatini-dashboard.html" },
    { "source": "/casestudy/studio-p", "destination": "/src/casestudy/studio-p.html" },
    { "source": "/casestudy/brt-platform", "destination": "/src/casestudy/brt-platform.html" },
    { "source": "/terms", "destination": "/src/legal/terms.html" },
    { "source": "/privacy", "destination": "/src/legal/privacy.html" },
    { "source": "/accessibility", "destination": "/src/legal/accessibility.html" },
    { "source": "/trust", "destination": "/src/legal/trust.html" },
    { "source": "/paths/soc2-readiness", "destination": "/src/paths/soc2-readiness.html" },
    { "source": "/agreements", "destination": "/src/agreements/service-agreement.html" },
    { "source": "/runbooks", "destination": "/src/runbooks/runbook-templates.html" },
    { "source": "/login", "destination": "/src/login/login.html" },
    { "source": "/onboard", "destination": "/src/onboarding/onboarding-form.html" }
  ]
}
